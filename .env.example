# BOB Claw starts in shadow mode. Do not add private keys until the executor phase.
BOB_GATEWAY_API_BASE=https://gateway-api-mainnet.gobob.xyz
BOB_CLAW_VERIFY_RECIPIENT=0x000000000000000000000000000000000000dEaD
BOB_CLAW_VERIFY_BTC_RECIPIENT=1BitcoinEaterAddressDontSendf59kuE
BOB_CLAW_SAMPLE_SATS=10000,25000,50000,100000,150000
BOB_CLAW_SLIPPAGE_BPS=50
BOB_CLAW_REQUEST_DELAY_MS=1500
BOB_CLAW_DATA_DIR=./data

# Gas snapshots use public RPC defaults first. Override later if reliability is poor.
# BOB_CLAW_GAS_BUFFER_MULTIPLIER will be wired into scoring once DEX gas is integrated.
BOB_CLAW_GAS_BUFFER_MULTIPLIER=2
# Comma-separated RPC failover lists. Use paid, self-hosted, or eRPC endpoints here later.
# BOB_CLAW_RPC_URLS_BERA=https://rpc.berachain.com,https://your-erpc-or-paid-bera-endpoint.example

# Run `npm run watch:gateway-updates` from cron/launchd/pm2 on the Mac mini.
# Recommended interval: hourly in early shadow mode, then every 6 hours when stable.

# Telegram will be wired after the route verifier is stable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
