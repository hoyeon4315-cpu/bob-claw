<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.bob-claw.autopilot</string>
  <key>WorkingDirectory</key>
  <string>/Users/love/BOB Claw</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>src/executor/all-chain-autopilot.mjs</string>
    <string>--loop</string>
    <string>--execute</string>
    <string>--write</string>
    <string>--interval-ms=300000</string>
    <string>--timeout-ms=300000</string>
